# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
TRUST_PROXY=false

# Comma-separated browser origins. Use explicit origins in production.
CORS_ORIGIN=http://localhost:3000

# PostgreSQL / Prisma (also required by ../database/prisma/schema.prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dsa_docs?schema=public

# Use long, random values in production (at least 32 characters each).
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Judge0 CE / self-hosted Judge0. Leave JUDGE0_API_KEY empty for self-hosted instances.
JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_API_KEY=
JUDGE0_API_HOST=
JUDGE0_TIMEOUT_MS=15000
JUDGE0_POLL_INTERVAL_MS=500
JUDGE0_MAX_POLL_ATTEMPTS=30
# Optional JSON override, e.g. {"PYTHON":71,"JAVASCRIPT":63}
JUDGE0_LANGUAGE_IDS=

# Abuse controls
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
EXECUTION_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_MAX=12
