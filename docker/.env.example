
# Use with: docker compose --env-file docker/.env up --build
# Copy this file to docker/.env and replace every value marked CHANGE_ME.

# Public edge port. Only nginx is published; PostgreSQL and Express remain on
# the internal Docker network.
APP_PORT=8080

# PostgreSQL
POSTGRES_USER=dsa
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD
POSTGRES_DB=dsa_docs

# Browser traffic goes to nginx, which proxies this same-origin path to Express.
NEXT_PUBLIC_API_URL=/api/v1

# Express
JWT_ACCESS_SECRET=CHANGE_ME_USE_A_32_PLUS_CHARACTER_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_USE_A_DIFFERENT_32_PLUS_CHARACTER_RANDOM_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=12
EXECUTION_RATE_LIMIT_MAX=20

# Judge0 is optional. Leave BASE_URL blank to disable remote execution until a
# Judge0 CE or managed endpoint is configured. Do not set this to a browser URL.
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
JUDGE0_API_HOST=
JUDGE0_TIMEOUT_MS=15000
JUDGE0_POLL_INTERVAL_MS=500
JUDGE0_MAX_POLL_ATTEMPTS=30
JUDGE0_LANGUAGE_IDS=
